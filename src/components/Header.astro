---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.tsx';
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
	<nav class="mx-auto flex max-w-[680px] items-center justify-between px-4 py-4">
		<a href={`${import.meta.env.BASE_URL}`} class="text-lg font-bold text-[var(--color-text)] no-underline">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-4">
			<a href={`${import.meta.env.BASE_URL}/tags/`} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] no-underline transition-colors">
				Tags
			</a>
			<ThemeToggle client:load />
		</div>
	</nav>
</header>
